{
  "$description": "DTCG design tokens (W3C Design Tokens Community Group format). Two-tier: primitives → semantics. Components reference ONLY semantic tokens. Compile to tokens.css via Tailwind v4 @theme or Style Dictionary. REPLACE the placeholder values — shipping these defaults unchanged is the AI-slop tell.",
  "color": {
    "brand": {
      "500": { "$value": "oklch(62% 0.19 265)", "$type": "color", "$description": "← REPLACE: your one saturated brand accent (not indigo-600)" },
      "600": { "$value": "oklch(55% 0.19 265)", "$type": "color" }
    },
    "neutral": {
      "0":   { "$value": "oklch(99% 0 0)", "$type": "color", "$description": "← REPLACE: pick a distinct neutral, not default slate/zinc" },
      "500": { "$value": "oklch(64% 0 0)", "$type": "color" },
      "950": { "$value": "oklch(18% 0 0)", "$type": "color" }
    },
    "semantic": {
      "bg":             { "$value": "{color.neutral.0}", "$type": "color" },
      "surface":        { "$value": "{color.neutral.0}", "$type": "color" },
      "border-subtle":  { "$value": "{color.neutral.500}", "$type": "color" },
      "text-primary":   { "$value": "{color.neutral.950}", "$type": "color" },
      "text-secondary": { "$value": "{color.neutral.500}", "$type": "color" },
      "action":         { "$value": "{color.brand.500}", "$type": "color" },
      "action-hover":   { "$value": "{color.brand.600}", "$type": "color" },
      "danger":         { "$value": "oklch(58% 0.20 25)", "$type": "color" },
      "success":        { "$value": "oklch(65% 0.17 145)", "$type": "color" }
    }
  },
  "space": {
    "1": { "$value": "4px",  "$type": "dimension" },
    "2": { "$value": "8px",  "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension", "$description": "← REPLACE: a deliberate radius vocabulary, not the framework default" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" }
  },
  "type": {
    "family": {
      "display": { "$value": "'← REPLACE — a real display face', system-ui, sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "'← REPLACE — a real body face', system-ui, sans-serif", "$type": "fontFamily" },
      "mono":    { "$value": "'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily" }
    },
    "body": { "$value": { "fontFamily": "{type.family.body}", "fontSize": "16px", "lineHeight": "1.5", "fontWeight": 400 }, "$type": "typography" },
    "h1":   { "$value": { "fontFamily": "{type.family.display}", "fontSize": "2rem", "lineHeight": "1.15", "fontWeight": 600 }, "$type": "typography" }
  },
  "motion": {
    "fast":     { "$value": "150ms", "$type": "duration" },
    "standard": { "$value": "300ms", "$type": "duration" },
    "ease-out": { "$value": "cubic-bezier(0.2, 0, 0, 1)", "$type": "cubicBezier" }
  },
  "signature": {
    "focus-ring": { "$value": "0 0 0 2px {color.brand.500}", "$type": "shadow", "$description": "The one deliberate token that is yours — the fingerprint that de-generics output." }
  }
}
