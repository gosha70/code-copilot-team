# ─────────────────────────────────────────────────────────────────────────
# session-analytics configuration template.
#
# Copy to `.env` (gitignored) or run `./scripts/session-analytics setup`, which
# generates `.env` interactively. The CLI and the Studio config page read AND
# write this same file — it is the single source of truth.
# Precedence: defaults < .env < real environment variables < CLI flags.
# ─────────────────────────────────────────────────────────────────────────

# Relational store. Leave the SQLite default for zero-infra local use, or point
# at PostgreSQL (docker-compose.yml brings one up on :5433).
#   SQLite (local file):  sqlite:////absolute/path/session-analytics.db
#   PostgreSQL:           postgresql://cct:cct@localhost:5433/session_analytics
CCT_SA_DSN=sqlite:////tmp/session-analytics.db

# Embedded Kùzu knowledge-graph directory.
CCT_SA_KUZU_PATH=

# Redaction applied before any DB write or judge prompt:
#   none | code | metadata-only   (default: code — strips code/secrets)
CCT_SA_REDACTION=code

# ── LLM-as-Judge ─────────────────────────────────────────────────────────
# DEFAULT (these blank) = local Ollama (model llama3) — fully local, no
# session content leaves the machine. Opting into a cloud judge is explicit:
#   Anthropic (sends REDACTED previews via the local claude CLI):
#     CCT_SA_JUDGE_BACKEND=claude-code  CCT_SA_JUDGE_MODEL=   (blank = Opus 4.8)
#   Local Ollama, other model:  CCT_SA_JUDGE_BACKEND=ollama  CCT_SA_JUDGE_MODEL=llama3
#   LM Studio / vLLM / OpenAI (OpenAI-compatible):
#     CCT_SA_JUDGE_BACKEND=openai  CCT_SA_JUDGE_MODEL=<model>
#     CCT_SA_JUDGE_BASE_URL=http://localhost:1234/v1   (LM Studio default)
#     CCT_SA_JUDGE_API_KEY=<key>   (for hosted endpoints; blank for local)
CCT_SA_JUDGE_BACKEND=
CCT_SA_JUDGE_MODEL=
CCT_SA_JUDGE_BASE_URL=
CCT_SA_JUDGE_API_KEY=
CCT_SA_JUDGE_WORKERS=2
CCT_SA_OLLAMA_URL=http://localhost:11434

# Optional: override a copilot's session source root.
# CCT_SA_SOURCE_CLAUDE_CODE=~/.claude/projects
