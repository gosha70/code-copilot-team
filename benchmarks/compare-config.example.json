    },
    {
      "name": "qwen-coder-via-ollama",
      "backend": "claude-code",
      "model": "qwen2.5-coder:32b",
      "env": {
        "ANTHROPIC_BASE_URL": "http://localhost:11434",
        "ANTHROPIC_AUTH_TOKEN": "dummy",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "qwen2.5-coder:32b"
      }
    }
  ]
