        "ANTHROPIC_BASE_URL": "http://localhost:8000",
        "ANTHROPIC_AUTH_TOKEN": "dummy-vllm-does-not-check",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "meta-llama/Llama-3-70B-Instruct"
