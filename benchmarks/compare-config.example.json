    {
      "name": "claude-sonnet-anthropic-api",
      "backend": "claude-code",
      "model": "sonnet"
    },
    {
      "name": "claude-opus-anthropic-api",
      "backend": "claude-code",
      "model": "opus"
    },
    {
      "name": "llama3-70b-via-vllm",
