CREATE REL TABLE IF NOT EXISTS HAS_TURN(FROM Session TO Turn)
CREATE REL TABLE IF NOT EXISTS INVOKED(FROM Turn TO ToolInvocation)
CREATE REL TABLE IF NOT EXISTS ACCESSED_FILE(FROM ToolInvocation TO FileNode, access_type STRING)
CREATE REL TABLE IF NOT EXISTS PRODUCED_ERROR(FROM ToolInvocation TO ErrorNode)
CREATE REL TABLE IF NOT EXISTS IN_WORKSPACE(FROM Session TO Workspace)
CREATE REL TABLE IF NOT EXISTS USED_AGENT(FROM Session TO Agent)
CREATE REL TABLE IF NOT EXISTS USED_MODEL(FROM Session TO Model)
CREATE REL TABLE IF NOT EXISTS RAN_ON(FROM Session TO Copilot)
CREATE REL TABLE IF NOT EXISTS BY_DEVELOPER(FROM Session TO Developer)
CREATE REL TABLE IF NOT EXISTS FOLLOWED_BY(FROM Turn TO Turn)
CREATE REL TABLE IF NOT EXISTS RETRIED(FROM ToolInvocation TO ToolInvocation)
CREATE REL TABLE IF NOT EXISTS SIMILAR_TO(FROM Session TO Session, score DOUBLE)
